{
  "name": "gatheraa-integration-tests",
  "version": "1.0.0",
  "description": "Integration tests for Gatheraa smart contracts",
  "main": "index.js",
  "scripts": {
    "test": "mocha --timeout 60000 --recursive",
    "test:cross-contract": "mocha test/cross-contract/*.test.ts --timeout 60000",
    "test:token-interactions": "mocha test/token-interactions/*.test.ts --timeout 60000",
    "test:end-to-end": "mocha test/end-to-end/*.test.ts --timeout 120000",
    "test:upgrades": "mocha test/upgrades/*.test.ts --timeout 60000",
    "build": "hardhat compile",
    "clean": "hardhat clean"
  },
  "keywords": ["blockchain", "smart-contracts", "integration-tests", "gatheraa"],
  "author": "Gatheraa Team",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.4",
    "@nomicfoundation/hardhat-ignition": "^3.0.7",
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.2",
    "@types/chai": "^4.3.20",
    "@types/chai-as-promised": "^8.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.7",
    "chai": "^5.3.3",
    "chai-as-promised": "^8.0.1",
    "ethers": "^6.16.0",
    "hardhat": "^3.1.5",
    "mocha": "^11.7.5",
    "typescript": "~5.8.0",
    "dotenv": "^16.4.5"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2"
  }
}
